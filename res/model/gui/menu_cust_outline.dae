    <revision>1.0</revision>
  </asset>
  <library_images>
    <image id="Board-diffuse-tex" name="Board-diffuse-tex">
      <init_from>menu_cust_outline_Board_diffuse.png</init_from>
    </image>
    <image id="Board-emissive-tex" name="Board-emissive-tex">
      <init_from>menu_cust_outline_Board_emissive.png</init_from>
    </image>
  </library_images>
  <library_effects>
    <effect id="Board-Effect">
      <profile_COMMON>
        <newparam sid="Board-diffuse-surface">
          <surface type="2D">
            <init_from>Board-diffuse-tex</init_from>
            <format>A8R8G8B8</format>
          </surface>
        </newparam>
        <newparam sid="Board-emissive-surface">
          <surface type="2D">
            <init_from>Board-emissive-tex</init_from>
            <format>A8R8G8B8</format>
          </surface>
        </newparam>
        <newparam sid="Board-diffuse-sampler">
          <sampler2D>
            <source>Board-diffuse-surface</source>
            <wrap_s>CLAMP</wrap_s>
            <wrap_t>CLAMP</wrap_t>
            <minfilter>NONE</minfilter>
            <magfilter>NONE</magfilter>
            <mipfilter>NONE</mipfilter>
          </sampler2D>
        </newparam>
        <newparam sid="Board-emissive-sampler">
          <sampler2D>
            <source>Board-emissive-surface</source>
            <wrap_s>CLAMP</wrap_s>
            <wrap_t>CLAMP</wrap_t>
            <minfilter>NONE</minfilter>
            <magfilter>NONE</magfilter>
            <mipfilter>NONE</mipfilter>
          </sampler2D>
        </newparam>
        <technique sid="phong1">
          <phong>
            <emission>
              <texture texcoord="Board-tex-bind" texture="Board-emissive-sampler"/>
            </emission>
            <ambient>
              <color>1.0 1.0 1.0 1.0</color>
            </ambient>
            <diffuse>
              <texture texcoord="Board-tex-bind" texture="Board-diffuse-sampler"/>
            </diffuse>
            <specular>
              <color>0.0 0.0 0.0 1.0</color>
            </specular>
            <shininess>
              <float>5.0</float>
            </shininess>
            <reflective>
              <color>1.0 1.0 1.0 1.0</color>
            </reflective>
            <reflectivity>
              <float>0.2</float>
            </reflectivity>
            <transparent>
              <color>1.0 1.0 1.0 1.0</color>
            </transparent>
            <transparency>
              <float>1.0</float>
            </transparency>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="Board-Material">
      <instance_effect url="#Board-Effect"/>
    </material>
  </library_materials>
